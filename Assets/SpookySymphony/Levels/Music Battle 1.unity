  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: What the heck! Who are you?!
  backgroundColor: {r: 1, g: 0, b: 0.5294118, a: 1}
  textColor: {r: 0, g: 0, b: 0, a: 1}
  targetObject: {fileID: 927335248}
