--- !u!114 &927335252
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 927335245}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: "Hm, I guess that wasn\u2019t so bad. But you better not bother
    me again. "
  backgroundColor: {r: 1, g: 0, b: 0.5294118, a: 1}
  textColor: {r: 0, g: 0, b: 0, a: 1}
  targetObject: {fileID: 0}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 0}
--- !u!114 &927335253
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 927335245}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: 'Ugh, fine. '
  backgroundColor: {r: 1, g: 0, b: 0.5294118, a: 1}
  textColor: {r: 0, g: 0, b: 0, a: 1}
  targetObject: {fileID: 927335248}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 0}
--- !u!114 &927335254
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 927335245}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: "Concert master\u2019s promise. "
  backgroundColor: {r: 0.1882353, g: 0.23921569, b: 0.2784314, a: 1}
  textColor: {r: 1, g: 1, b: 1, a: 1}
  targetObject: {fileID: 927335248}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 927335253}
--- !u!114 &927335255
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 927335245}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: "*Huffs* My name is Esmeralda. How do I know you\u2019ll actually
    leave me alone? "
  backgroundColor: {r: 1, g: 0, b: 0.5294118, a: 1}
  textColor: {r: 0, g: 0, b: 0, a: 1}
  targetObject: {fileID: 927335248}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 927335254}
--- !u!114 &927335256
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 927335245}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: 'Halt, mortal! Sing one ballad with me, and I shall bother you no
    more. But before you join me in my serenade, tell me your name. '
  backgroundColor: {r: 0.1882353, g: 0.23921569, b: 0.2784314, a: 1}
  textColor: {r: 1, g: 1, b: 1, a: 1}
  targetObject: {fileID: 927335248}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 927335255}
--- !u!114 &927335257
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 927335245}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: 'That sucks pal, but I have ghosts to catch here. '
  backgroundColor: {r: 1, g: 0, b: 0.5294118, a: 1}
  textColor: {r: 0, g: 0, b: 0, a: 1}
  targetObject: {fileID: 927335248}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 927335256}
--- !u!114 &927335258
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 927335245}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: "*Sighs* No one wants to sing in my concerts anymore, I\u2019ve
    been so lonely for over a 100 years\u2026 "
  backgroundColor: {r: 0.1882353, g: 0.23921569, b: 0.2784314, a: 1}
  textColor: {r: 1, g: 1, b: 1, a: 1}
  targetObject: {fileID: 927335248}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 927335257}
--- !u!114 &927335259
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 927335245}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: "*Looks annoyed* I don\u2019t have time for that, I need to vlog
    some ghosts and get out of here! "
  backgroundColor: {r: 1, g: 0, b: 0.5294118, a: 1}
  textColor: {r: 0, g: 0, b: 0, a: 1}
  targetObject: {fileID: 927335248}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 927335258}
--- !u!114 &927335260
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 927335245}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: 'I am the concert master, Herbert Von Reginald. Have you come to
    take part in my magnificent symphony? '
  backgroundColor: {r: 0.1882353, g: 0.23921569, b: 0.2784314, a: 1}
  textColor: {r: 1, g: 1, b: 1, a: 1}
  targetObject: {fileID: 927335248}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 927335259}
--- !u!114 &927335261
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 927335245}
  m_Enabled: 1
